 Copy this file to .env and fill in your own values.
# .env is gitignored; this template is the tracked reference.
# cargo-make loads .env automatically (see env_files in Makefile.toml) -
# no need to export these yourself or run `source`.

# From `xcrun devicectl list devices` - needed for `cargo make ios-run-device`
IOS_DEVICE_ID=

# Android release signing keystore - needed for `cargo make android-release`
# (matches [package.metadata.android.signing.release] in gui/Cargo.toml)
CARGO_APK_RELEASE_KEYSTORE=
CARGO_APK_RELEASE_KEYSTORE_PASSWORD=
